rules_version = '2';

service firebase.storage {
  match /b/{bucket}/o {

    // Bloqueia tudo por padrão
    match /{allPaths=**} {
      allow read, write: if false;
    }

    // Imagens e arquivos públicos: leitura liberada
    match /public/{allPaths=**} {
      allow read: if true;
      allow write: if false;
    }

    // Uploads administrativos: apenas leitura autenticada
    // Escrita ocorre exclusivamente via signed URL gerado pelo backend
    match /uploads/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if false;
    }
  }
}